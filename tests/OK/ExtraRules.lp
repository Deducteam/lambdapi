// This module turns proved equalities to rewrite rules

require open tests.OK.Bool;
require tests.OK.Nat as N;
require open tests.OK.List;
require tests.OK.Pos as P;
require tests.OK.Z as Z;

// Bool

rule _ or true  в†Є true
with $b or false в†Є $b;

// Nat

rule $x N.+ N._0 в†Є $x;
rule $x N.+ $y N.+1 в†Є ($x N.+ $y) N.+1;
rule ($x N.+ $y) N.+ $z в†Є $x N.+ ($y N.+ $z);
rule $x N.- N._0 в†Є $x;
rule _ N.* N._0 в†Є N._0;
rule N.max $x N._0 в†Є $x;
rule N.max $x $x в†Є $x;
rule N.min _ N._0 в†Є N._0;
rule N.min $x $x в†Є $x;

// List

rule $m ++ в–Ў в†Є $m;
rule size ($l ++ $m) в†Є size $l N.+ size $m;
rule ($l ++ $m) ++ $n в†Є $l ++ ($m ++ $n);
rule last _ ($e вё¬ $l) в†Є last $e $l;
rule nth $x в–Ў _ в†Є $x;
rule drop _ в–Ў в†Є в–Ў;
rule take _ в–Ў в†Є в–Ў;

// Pos

rule P.add $x P.H в†Є P.succ $x
with P.add P.H $y в†Є P.succ $y;
rule P.add_carry $x P.H в†Є P.add $x (P.O P.H)
with P.add_carry P.H $y в†Є P.add (P.O P.H) $y;

// Z

rule $x Z.+ Z.Z0 в†Є $x;
