/* example of inductive-inductive type:

contexts and types in dependent type theory

page 31 of Forsberg's 2013 PhD thesis "Inductive-inductive definitions"
http://www.cs.swan.ac.uk/~csetzer/articlesFromOthers/nordvallForsberg/phdThesisForsberg.pdf
*/

// definitions needed for expressing induction principles

constant symbol Prop : TYPE;
builtin "Prop" в‰” Prop;

injective symbol ПЂ : Prop в†’ TYPE;
builtin "Prf" в‰” ПЂ;

// contexts
inductive Con : TYPE в‰”
| в–Ў : Con
| в‹… О“ : Ty О“ в†’ Con

// types
with Ty : Con в†’ TYPE в‰”
| U О“ : Ty О“
| P О“ (a : Ty О“) : Ty (в‹… О“ a) в†’ Ty О“;

notation в‹… infix left 10;

/* generated induction principles:

print ind_Con;
print ind_Ty;

after some renamings we get:

symbol ind_Con:
  О  p: Con в†’ Prop,
  О  q: (О  О“: Con, Ty О“ в†’ Prop),
  ПЂ (p в–Ў) в†’
  (О  О“: Con, ПЂ (p О“) в†’ О  A: Ty О“, ПЂ (q О“ A) в†’ ПЂ (p (О“ в‹… A))) в†’
  (О  О“: Con, ПЂ (p О“) в†’ ПЂ (q О“ (U О“))) в†’
  (О  О“: Con, ПЂ (p О“) в†’ О  A: Ty О“, ПЂ (q О“ A) в†’ О  B: Ty (О“ в‹… A), ПЂ (q (О“ в‹… A) B) в†’ ПЂ (q О“ (P О“ A B))) в†’
  О  О“: Con, ПЂ (p О“)

rules:

  ind_Con $p $q $hв–Ў $hв‹… $hU $hP в–Ў в†Є $hв–Ў

  ind_Con $p $q $hв–Ў $hв‹… $hU $hP ($О“ в‹… $A)
  в†Є $hв‹… $О“ (ind_Con $p $q $hв–Ў $hв‹… $hU $hP $О“)
        $A (ind_Ty $p $q $hв–Ў $hв‹… $hU $hP $О“ $A)

symbol ind_Ty:
  О  p: (Con в†’ Prop),
  О  q: (О  О“: Con, Ty О“ в†’ Prop),
  ПЂ (p в–Ў) в†’
  (О  О“: Con, ПЂ (p О“) в†’ О  A: Ty О“, ПЂ (q О“ A) в†’ ПЂ (p (О“ в‹… A))) в†’
  (О  О“: Con, ПЂ (p О“) в†’ ПЂ (q О“ (U О“))) в†’
  (О  О“: Con, ПЂ (p О“) в†’ О  A: Ty О“, ПЂ (q О“ A) в†’
                       О  B: Ty (О“ в‹… A), ПЂ (q (О“ в‹… A) B) в†’ ПЂ (q О“ (P О“ A B))) в†’
  О  О“: Con, О  A: Ty О“, ПЂ (q О“ A)

rules:

  ind_Ty $p $q $hв–Ў $hв‹… $hU $hP $О“ (U _)
  в†Є $hU $О“ (ind_Con $p $q $hв–Ў $hв‹… $hU $hP $О“)

  ind_Ty $p $q $hв–Ў $hв‹… $hU $hP $О“ (P _ $A $B)
  в†Є $hP $О“ (ind_Con $p $q $hв–Ў $hв‹… $hU $hP $О“)
        $A (ind_Ty $p $q $hв–Ў $hв‹… $hU $hP $О“ $A)
        $B (ind_Ty $p $q $hв–Ў $hв‹… $hU $hP ($О“ в‹… $A) $B)
*/

// a more dependent induction principle can be defined by hand:

symbol ind_Con' :
  О  p : Con в†’ Prop,
  О  q : (О  О“, ПЂ (p О“) в†’ Ty О“ в†’ Prop),
  ПЂ (p в–Ў) в†’
  О  hв‹… : (О  О“, О  hО“ : ПЂ (p О“), О  A, ПЂ (q О“ hО“ A) в†’ ПЂ (p (О“ в‹… A))),
  (О  О“, О  hО“ : ПЂ (p О“), ПЂ (q О“ hО“ (U О“))) в†’
  (О  О“, О  hО“ : ПЂ (p О“), О  A, О  hA : ПЂ (q О“ hО“ A), О  B,
    ПЂ (q (О“ в‹… A) (hв‹… О“ hО“ A hA) B) в†’ ПЂ (q О“ hО“ (P О“ A B))) в†’
  О  О“, ПЂ (p О“);

symbol ind_Ty' :
  О  p : Con в†’ Prop,
  О  q : (О  О“, ПЂ (p О“) в†’ Ty О“ в†’ Prop),
  ПЂ (p в–Ў) в†’
  О  hв‹… : (О  О“, О  hО“ : ПЂ (p О“), О  A, ПЂ (q О“ hО“ A) в†’ ПЂ (p (О“ в‹… A))),
  (О  О“, О  hО“ : ПЂ (p О“), ПЂ (q О“ hО“ (U О“))) в†’
  (О  О“, О  hО“ : ПЂ (p О“), О  A, О  hA : ПЂ (q О“ hО“ A), О  B,
    ПЂ (q (О“ в‹… A) (hв‹… О“ hО“ A hA) B) в†’ ПЂ (q О“ hО“ (P О“ A B))) в†’
  О  О“, О  hО“ : ПЂ (p О“), О  A, ПЂ (q О“ hО“ A);

rule ind_Con' _ _ $hв–Ў _ _ _ в–Ў в†Є $hв–Ў;

rule ind_Con' $p $q $hв–Ў $hв‹… $hU $hP ($О“ в‹… $A)
в†Є let hО“ в‰” ind_Con' $p $q $hв–Ў $hв‹… $hU $hP $О“ in
  $hв‹… $О“ hО“ $A (ind_Ty' $p $q $hв–Ў $hв‹… $hU $hP $О“ hО“ $A);

rule ind_Ty' $p $q $hв–Ў $hв‹… $hU $hP $О“ $hО“ (U _)
в†Є $hU $О“ $hО“;

rule ind_Ty' $p $q $hв–Ў $hв‹… $hU $hP $О“ $hО“ (P _ $A $B)
в†Є let hA в‰” ind_Ty' $p $q $hв–Ў $hв‹… $hU $hP $О“ $hО“ $A in
  let hО“в‹…A в‰” $hв‹… $О“ $hО“ $A hA in
  $hP $О“ $hО“ $A hA $B (ind_Ty' $p $q $hв–Ў $hв‹… $hU $hP ($О“ в‹… $A) hО“в‹…A $B);
