msolve Goals RES :- std.map Goals (open tc) RES.

%add_abst Ty (x\O) lambda-binds x with type Ty inside O.
pred add_abst term, (term -> option term) -> option term.
add_abst _ (_\none) none.

add_abst Ty (x\ some (T x)) (some (abst Ty T)).

/* load the goal's context (possibly adding new local typeclass instances)
   before trying typeclass resolution if the goal is a typeclass
   returns an instance if it finds one, and none otherwise
*/
pred open i:(symbol -> term -> term -> prop), i:sealed-goal, o:option term.
open P (nabla Ty F) Abswit :- pi x\ sigma Rule\ (comp Ty [] x Rule ; Rule = true),
  Rule ==> open P (F x) (Wit x), add_abst Ty Wit Abswit.

open P (seal (goal Ty Wit)) (some Wit) :- 
  safe-dest-app Ty (symb Class) [X],
  not (var Class),
  lp.tc? Class, !,
  P Class X Wit.

open _ (seal (goal _ _)) none.

%[tc Name Arg Inst] <=> Inst is an instance of (Name Arg)
%(currently, typeclasses must have exactly one argument)
pred tc o:symbol, o:term, o:term.

%splits a term between its head and args (without reductions)
pred safe-dest-app i:term, o:term, o:list term.
safe-dest-app (appl HD ARG) H AS :- !,
  safe-dest-app HD H A,
  std.append A [ARG] AS.
safe-dest-app X X [].

%tries to compile a symbol's type into a typeclass instance rule
external pred compile i:symbol o:prop.

compile S RES :- comp {lp.sig S} [] (symb S) RES.

pred comp i:term, i:list prop, i:term, o:prop.

comp (prod (appl T U) F) TODO H (pi x\ C x) :-
  T = symb S, lp.tc? S,
  !,
  pi x\
    comp (F x) [tc S U x |TODO] (appl H x) (C x).

comp (prod _ F) TODO H (pi x\ C x) :-
  !,
  pi x\
    comp (F x) TODO (appl H x) (C x).

comp End TODO HD (tc S U HD :- TODO) :- safe-dest-app End (symb S) [U], lp.tc? S. 