msolve L RES :-
  print "### GOALS: " L,
  /*comp_all Cl,
  print "RULES:" Cl,
  Cl => */std.map L (open tc) RES,
  print "RESULT:" RES.

pred add_abst term, (term -> option term) -> option term.
add_abst _ (x\none) none.

add_abst Ty (x\ some (T x)) (some (abst Ty T)).

pred open i:(symbol -> term -> term -> prop), i:sealed-goal, o:option term.
open P (nabla Ty F) Abswit :- pi x\ sigma Rule\ (comp Ty [] x Rule ; Rule = true),
  Rule ==> open P (F x) (Wit x), add_abst Ty Wit Abswit.

open P (seal (goal /*Ctx*/ Ty Wit)) (some Wit) :- 
  print "TC PROBLEM:\n" /*Ctx*/ "|-\n" Wit ":" Ty "\n",
  safe-dest-app Ty (symb Class) [X],
  not (var Class),
  lp.tc? Class, !, print "GOAL:" (P Class X Wit),
  P Class X Wit,
  print "TC INSTANCE:\n" /*Ctx*/ "|-\n" Wit ":" Ty "\n".

open _ (seal (goal /*Ctx*/ Ty Wit)) none :-
  print "NOT A TC INFERENCE PROBLEM:\n" /*Ctx*/ "|-\n" Wit ":" Ty "\n".

