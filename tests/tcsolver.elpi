comp (prod (appl T U) F) TODO H (pi x\ C x) :-
  print (appl T U), T = symb S, std.spy (lp.tc? S),
  !,
  pi x\
    comp (F x) [tc S U x |TODO] (appl H x) (C x).

comp (prod _ F) TODO H (pi x\ C x) :-
  !,
  pi x\
    comp (F x) TODO (appl H x) (C x).
