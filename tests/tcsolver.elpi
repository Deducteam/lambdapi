recover-type T (nabla F) Ty :- pi x\ recover-type T (F x) Ty.

recover-type T (seal (goal Ctx _ _)) Ty :- memo! Ctx (of T Ty).*/

/*%std.mem! but outputs the element.
func memo! list A -> A.
memo! [X|_] X :- !.
memo! [_|L] X :- memo! L X.*/


pred tc o:symbol, o:term, o:term.

pred safe-dest-app i:term, o:term, o:list term.
safe-dest-app (appl HD ARG) H AS :- !,
  safe-dest-app HD H A,
  std.append A [ARG] AS.
safe-dest-app X X [].

external pred compile i:symbol o:prop.

compile S RES :- comp {lp.sig S} [] (symb S) RES, print RES.

pred comp i:term, i:list prop, i:term, o:prop.
